# Copy to .env and fill in. Both tokens come from your Slack app (see README).
# Bot token — Slack app > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...
# App-level token with connections:write — Slack app > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# Optional
# TZ=America/Los_Angeles
# LOG_LEVEL=INFO
# LUNCHBOT_DB=./lunchbot.db
